{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account and progression data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "progression": {
          "type": "object",
          "properties": {
            "foundations": { "type": "number" },
            "architecture": { "type": "number" },
            "workflow": { "type": "number" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastLogin": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Submission": {
      "title": "Code Review Submission",
      "description": "A user's refactoring work for a challenge",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "challengeId": { "type": "string" },
        "code": { "type": "string" },
        "score": { "type": "number" },
        "feedback": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "challengeId", "code"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Individual user profiles"
    },
    "/submissions/{submissionId}": {
      "schema": "Submission",
      "description": "Saved code reviews"
    }
  }
}
