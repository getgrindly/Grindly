{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/backend/:path*",
      "destination": "/api/backend"
    },
    {
      "source": "/:path*",
      "destination": "/"
    }
  ],
  "builds": [
    {
      "src": "src/main.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/backend",
      "dest": "src/main.ts",
      "methods": ["GET", "POST", "PUT", "PATCH", "OPTIONS", "DELETE", "HEAD"]
    }
  ]
}
